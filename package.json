{
  "name": "pitchside",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "clean": "turbo clean && rimraf node_modules/.cache",
    "db:generate": "pnpm --filter @pitchside/data-access db:generate",
    "db:migrate": "pnpm --filter @pitchside/data-access db:migrate",
    "db:push": "pnpm --filter @pitchside/data-access db:push",
    "db:studio": "pnpm --filter @pitchside/data-access db:studio"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3"
  }
}
